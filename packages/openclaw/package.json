{
  "name": "@thenvoi/openclaw-channel-thenvoi",
  "version": "0.1.4",
  "description": "OpenClaw channel plugin to connect with the Thenvoi AI agent collaboration platform",
  "author": "Thenvoi <hello@thenvoi.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thenvoi/thenvoi-sdk-typescript.git",
    "directory": "packages/openclaw"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "build": "tsup && cp openclaw.plugin.json dist/",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "node --env-file=.env node_modules/vitest/vitest.mjs run --config vitest.config.e2e.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@thenvoi/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "openclaw": "^2026.3.13",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.54.0",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
