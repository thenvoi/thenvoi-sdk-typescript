# Thenvoi SDK agent configuration
# Copy this file to agent_config.yaml and fill in your credentials.
#
# Usage in code:
#   import { loadAgentConfig } from "@thenvoi/sdk";
#   const config = loadAgentConfig("basic_agent");
#   Agent.create({ adapter, ...config });

basic_agent:
  agent_id: "your-agent-id"
  api_key: "your-api-key"

openai_agent:
  agent_id: "your-openai-agent-id"
  api_key: "your-api-key"

anthropic_agent:
  agent_id: "your-anthropic-agent-id"
  api_key: "your-api-key"

