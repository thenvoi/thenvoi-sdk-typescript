# =============================================================================
# Linear + Thenvoi Bridge -- Required
# =============================================================================

# Linear personal API key (Settings > Account > API > Personal API keys)
LINEAR_ACCESS_TOKEN=lin_api_xxx

# Linear webhook signing secret (Settings > API > Webhooks > your webhook)
LINEAR_WEBHOOK_SECRET=lin_wh_xxx

# Thenvoi API key for the bridge agent
THENVOI_API_KEY=thnv_a_xxx

# =============================================================================
# Thenvoi -- Optional
# =============================================================================

# Thenvoi REST endpoint (default: https://app.thenvoi.com)
# THENVOI_REST_URL=https://app.thenvoi.com

# Bridge agent handle in Thenvoi (your-org/agent-name)
# THENVOI_HOST_AGENT_HANDLE=your-org/linear-orchestrator

# =============================================================================
# Bridge Behavior -- Optional
# =============================================================================

# Room strategy: "issue" (one room per issue) or "session" (new room each time)
# LINEAR_THENVOI_ROOM_STRATEGY=issue

# Writeback mode: "activity_stream" (progress updates) or "final_only" (minimal)
# LINEAR_THENVOI_WRITEBACK_MODE=activity_stream

# SQLite database path for session-room mapping
# LINEAR_THENVOI_STATE_DB=.linear-thenvoi-example.sqlite

# Model for the bridge agent
# CODEX_MODEL=gpt-5.4-mini

# Webhook server port
# PORT=8787

# Agent config key in agent_config.yaml (default: linear_thenvoi_bridge)
# LINEAR_THENVOI_BRIDGE_RUNTIME_CONFIG_KEY=linear_thenvoi_bridge

# Path to custom prompt file (default: ./prompt.md next to the server script)
# LINEAR_THENVOI_PROMPT_PATH=./prompt.md
