{
  "name": "@thenvoi/sdk",
  "version": "0.1.6",
  "description": "Thenvoi TypeScript SDK core runtime",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thenvoi/thenvoi-sdk-typescript.git",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters.d.ts",
      "import": "./dist/adapters.js",
      "require": "./dist/adapters.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./converters": {
      "types": "./dist/converters.d.ts",
      "import": "./dist/converters.js",
      "require": "./dist/converters.cjs"
    },
    "./linear": {
      "types": "./dist/linear.d.ts",
      "import": "./dist/linear.js",
      "require": "./dist/linear.cjs"
    },
    "./rest": {
      "types": "./dist/rest.d.ts",
      "import": "./dist/rest.js",
      "require": "./dist/rest.cjs"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js",
      "require": "./dist/runtime.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./mcp": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js",
      "require": "./dist/mcp.cjs"
    },
    "./mcp/claude": {
      "types": "./dist/mcp-claude.d.ts",
      "import": "./dist/mcp-claude.js",
      "require": "./dist/mcp-claude.cjs"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist",
    "dev:linear": "tsx examples/linear-thenvoi/linear-thenvoi-bridge-server.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@thenvoi/rest-client": "0.0.113",
    "js-yaml": "^4.1.1",
    "phoenix": "^1.8.4",
    "ws": "^8.19.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.1"
  },
  "peerDependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@agentclientprotocol/sdk": "^0.16.1",
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/adk": "^0.5.0",
    "@google/genai": "^1.44.0",
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "^1.2.0",
    "@linear/sdk": "^76.0.0",
    "@letta-ai/letta-client": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.10.0",
    "@openai/codex-sdk": "^0.107.0",
    "@opencode-ai/sdk": "^1.3.0",
    "ai": "^6.0.137",
    "express": "^5.2.1",
    "openai": "^6.27.0",
    "parlant-client": "^3.2.0"
  },
  "peerDependenciesMeta": {
    "@a2a-js/sdk": {
      "optional": true
    },
    "@agentclientprotocol/sdk": {
      "optional": true
    },
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/adk": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    },
    "@langchain/core": {
      "optional": true
    },
    "@langchain/langgraph": {
      "optional": true
    },
    "@letta-ai/letta-client": {
      "optional": true
    },
    "@linear/sdk": {
      "optional": true
    },
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "@openai/codex-sdk": {
      "optional": true
    },
    "@opencode-ai/sdk": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "express": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "parlant-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@anthropic-ai/claude-agent-sdk": "^0.2.63",
    "@linear/sdk": "^76.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openai/codex-sdk": "^0.107.0",
    "@opencode-ai/sdk": "^1.3.0",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "@vitest/coverage-v8": "3.2.4",
    "ai": "^6.0.137",
    "eslint": "^9.22.0",
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  }
}
